{
  "manifest_version": "2.0",
  "name": "dev-tools-toolbox",
  "description": "Universal builder toolbox for installing a project-local .dev-tools sidecar, scaffolding setup-first doctrine, and carrying builder tools, packages, and onboarding surfaces into fresh projects.",
  "portable_project": true,
  "isolated_folder": true,
  "status": "active",
  "schema_version": "2.0.0",
  "recommended_folders": [
    "src/tools",
    "src/lib",
    "src/ui",
    "src/jobs",
    "assets"
  ],
  "mechanical_contract": {
    "cli_commands": [
      "metadata",
      "run --input-json '{...}'",
      "run --input-file path/to/input.json"
    ],
    "mcp_transport": "stdio",
    "result_envelope_keys": [
      "status",
      "tool",
      "input",
      "result"
    ]
  },
  "vendoring": {
    "mode": "full_sidecar",
    "sidecar_dir": ".dev-tools",
    "consumer_rule": "Install the full sidecar .dev-tools payload into a target project, then run project_setup from inside that project.",
    "verification": "python src/smoke_test.py"
  },
  "mcp_entrypoint": "src/mcp_server.py",
  "installer_entrypoint": "install.py",
  "self_test_entrypoint": "src/smoke_test.py",
  "tools": [
    {
      "tool_name": "journal_init",
      "script": "src/tools/journal_init.py",
      "mcp_name": "journal_init",
      "category": "bootstrap"
    },
    {
      "tool_name": "journal_manifest",
      "script": "src/tools/journal_manifest.py",
      "mcp_name": "journal_manifest",
      "category": "introspection"
    },
    {
      "tool_name": "journal_write",
      "script": "src/tools/journal_write.py",
      "mcp_name": "journal_write",
      "category": "write"
    },
    {
      "tool_name": "journal_query",
      "script": "src/tools/journal_query.py",
      "mcp_name": "journal_query",
      "category": "query"
    },
    {
      "tool_name": "journal_export",
      "script": "src/tools/journal_export.py",
      "mcp_name": "journal_export",
      "category": "export"
    },
    {
      "tool_name": "journal_acknowledge",
      "script": "src/tools/journal_acknowledge.py",
      "mcp_name": "journal_acknowledge",
      "category": "contract"
    },
    {
      "tool_name": "journal_actions",
      "script": "src/tools/journal_actions.py",
      "mcp_name": "journal_actions",
      "category": "ledger"
    },
    {
      "tool_name": "journal_scaffold",
      "script": "src/tools/journal_scaffold.py",
      "mcp_name": "journal_scaffold",
      "category": "scaffold"
    },
    {
