# Python build / runtime
__pycache__/
*.pyc
*.pyo
.venv/
venv/
runtime/
.dev-tools/runtime/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Editor / IDE
.idea/
.vscode/
*.swp
*.swo

# Claude Code harness local state (contains absolute user paths and permissions)
.claude/

# Secrets / credentials — never commit
.env
.env.*
*.key
*.pem
*.pfx
*.p12
credentials.json
secrets.json

# Logs
*.log
_logs/

# Runtime journal state (generated on demand by journal_init)
_docs/_AppJOURNAL/journal_config.json
_docs/_AppJOURNAL/db_manifest.json
_docs/_AppJOURNAL/exports/*
!_docs/_AppJOURNAL/exports/.gitkeep
_docs/_journalDB/app_journal.sqlite3

# v2 build workspace — installed sidecar inside _v2-pod is a copy of the
# parent toolkit and should not be tracked. Wrapper artifacts (Dockerfile,
# k8s manifests, scripts) inside _v2-pod ARE tracked.
_v2-pod/.dev-tools/
_v2-pod/_docs/_AppJOURNAL/
_v2-pod/_docs/_journalDB/
